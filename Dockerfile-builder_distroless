# 1.26.1-alpine3.23 (linux/amd64)
FROM golang:1.26.2-alpine3.23@sha256:c2a1f7b2095d046ae14b286b18413a05bb82c9bca9b25fe7ff5efef0f0826166 AS builder

RUN apk add --no-cache curl wget gcc make bash git musl-dev libc6-compat gettext

WORKDIR /app

COPY . .

RUN go build ./...

RUN go test ./... -race

# So the binary is where we expect it
# env var and flags ensure a static binary
RUN CGO_ENABLED=0 go build -ldflags="-extldflags=-static" -o prometheus-cardinality-exporter .

FROM scratch

EXPOSE 9090

COPY --from=builder /app/prometheus-cardinality-exporter /home/app/prometheus-cardinality-exporter

USER 255999

ENTRYPOINT ["/home/app/prometheus-cardinality-exporter"]
